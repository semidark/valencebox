node_modules/
dist/
*.log

# local Claude Code state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# QEMU configure probes (ephemeral build artifacts)
config-temp/

# QEMU build artifacts (scripts/build-qemu.sh)
build/qemu/

# v86 build output (regenerate: ./scripts/build-v86.sh)
/build/

# sandbox app build artifacts (regenerate: npm run images && npm run build)
sandbox/images/
sandbox/guest/sync-agent.bin
sandbox/guest/blake2sum.bin
sandbox/assets/v86/
sandbox/snapshots/
sandbox/workspace/
sandbox/build/

# QEMU bundled binary + firmware (regenerate: scripts/build-qemu.sh (Linux) or scripts/build-qemu.ps1 (Windows))
sandbox/resources/qemu/linux/qemu-system-x86_64
sandbox/resources/qemu/linux/pc-bios/*
sandbox/resources/qemu/win32/qemu-system-x86_64.exe
sandbox/resources/qemu/win32/*.dll
sandbox/resources/qemu/win32/pc-bios/*